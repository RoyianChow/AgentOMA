# ---------------------------------------------------------------------------
# Copy to .env.local and fill in real values. `.env*` is gitignored — NEVER
# commit real secrets. `src/env.ts` validates these; a missing/invalid required
# value fails the build (see next.config.ts).
# ---------------------------------------------------------------------------

# --- App -------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Primary datastore: Supabase Postgres (region ca-central-1 / Canada Central) ---
# PHIPA residency: keep this instance in a Canadian region. Pooled URL for the app:
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-ca-central-1.pooler.supabase.com:6543/postgres"
# Direct (non-pooled) URL for migrations / drizzle-kit. Optional (falls back to DATABASE_URL):
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-ca-central-1.pooler.supabase.com:5432/postgres"

# --- better-auth (sole identity layer; no Firebase/Supabase Auth) ----------
# Generate a 32+ char secret, e.g.  openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-a-long-random-secret-at-least-32-chars"
BETTER_AUTH_URL="http://localhost:3000"

# --- Supabase Storage (Rx / referral PDFs) ---------------------------------
# Server-side use only. Do NOT expose the service role key to the client.
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="replace-with-supabase-service-role-key"
SUPABASE_STORAGE_BUCKET="clinical-documents"

# --- Clinical viewer link-out (ConnectingOntario / ClinicalConnect) --------
# Optional stub used by the claim-history gate's attestation link.
CLINICAL_VIEWER_BASE_URL="https://clinicalconnect.example/"
